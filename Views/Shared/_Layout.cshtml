@inject IConfiguration Configuration
@{
    var shortName = Configuration["Institution:ShortName"] ?? "MAUN Tomer";
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
    var showAdminNavigation = controllerName == "Certificates" || controllerName == "AdminUsers" || User.Identity?.IsAuthenticated == true;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @shortName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MAUN.Tomer.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand brand-lockup" asp-area="" asp-controller="CertificateValidation" asp-action="Index">
                    <img src="~/img/maun-tomer-logo.svg" alt="MAUN Tomer" />
                </a>
                @if (showAdminNavigation)
                {
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Menüyü aç/kapat">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="CertificateValidation" asp-action="Index">Sertifika Sorgulama</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Certificates" asp-action="Index">Yönetim</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="AdminUsers" asp-action="Index">Kullanıcılar</a>
                            </li>
                        </ul>
                        <div class="navbar-nav admin-nav">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="navbar-text me-2 admin-user-name">@User.Identity.Name</span>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-dark">Çıkış</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            Copyright © 2026 Muş Alparslan Üniversitesi Bilgi İşlem Daire Başkanlığı - MAUN Tomer
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
