<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MAUN Tomer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MAUN.Tomer.Web.styles.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <main role="main" class="auth-main">
        @RenderBody()
    </main>

    <footer class="auth-footer">
        Copyright © 2026 Muş Alparslan Üniversitesi Bilgi İşlem Daire Başkanlığı - MAUN Tomer
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
