@model IReadOnlyList<MAUN.Tomer.Web.Models.AdminUser>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<section class="admin-hero-band user-hero-band">
    <div>
        <span class="admin-eyebrow">MAUN Tomer Yönetim Paneli</span>
        <h1>Kullanıcı Yönetimi</h1>
        <p>Admin paneline erişebilecek kullanıcıları oluşturun, düzenleyin ve pasif hale getirin.</p>
    </div>
    <div class="heading-actions admin-actions">
        <a class="btn btn-warning" asp-action="Create">Yeni Kullanıcı</a>
    </div>
</section>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<div class="admin-table-surface">
    <div class="table-toolbar">
        <div>
            <h2>Kullanıcı Listesi</h2>
            <p>@Model.Count kullanıcı kayıtlı</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle admin-table">
            <thead>
                <tr>
                    <th>Kullanıcı Adı</th>
                    <th>Ad Soyad</th>
                    <th>Durum</th>
                    <th>Oluşturma</th>
                    <th>Son Giriş</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Username</td>
                        <td>@item.FullName</td>
                        <td>
                            <span class="status-badge @(item.IsActive ? "status-pass" : "status-fail")">
                                @(item.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@(item.LastLoginAt.HasValue ? item.LastLoginAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "-")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.AdminUserId">Düzenle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
